# Copy to .env and fill in values

# ── Core ��─────────────────────────────────────────────
ENVIRONMENT=development

# ── PostgreSQL (question bank) — REQUIRED ─────────────
# For docker-compose: postgresql://study:<POSTGRES_PASSWORD>@postgres:5432/studyhelper
# For local dev:      postgresql://study:<password>@localhost:5432/studyhelper
DATABASE_URL=postgresql://study:changeme@localhost:5432/studyhelper

# Docker Compose PostgreSQL credentials
POSTGRES_USER=study
POSTGRES_DB=studyhelper
POSTGRES_PASSWORD=changeme_use_strong_password

# ── Supabase ──────────────────────────────────────────
# https://supabase.com/dashboard/project/<project>/settings/api
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret
# Direct DB connection (Transaction Pooler recommended)
# Supabase Dashboard > Settings > Database > Connection string > Transaction
SUPABASE_DB_URL=postgresql://postgres.xxxx:password@aws-0-ap-northeast-2.pooler.supabase.com:6543/postgres

# ── Redis ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_TLS_ENABLED=false

# ── AWS ───────���───────────────────────────────────────
AWS_REGION=ap-northeast-2
AWS_S3_BUCKET=fundamentals-pdf-temp

# ── AI Models ─────────────────────────────────────────
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_TIMEOUT=30

# OpenAI (gpt plan) — user provides their own key at request time
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT=60

# TimelyGPT (timely plan) — https://timelygpt.co.kr — user provides their own key
TIMELY_MODEL=gpt-4.1
TIMELY_TIMEOUT=60

# ── PDF Processing ────────────────────────────────────
MAX_PDF_PAGES=50
MAX_PDF_SIZE_MB=20

# ── CORS ────���─────────────────────────────────────────
# Comma-separated or JSON array format
# Development: ["http://localhost:3000","http://localhost:8081"]
# Production:  ["https://yourapp.com"]
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:8081"]

# ── Rate Limiting ─────────────────────────────────────
# Max requests per minute per IP
RATE_LIMIT_PER_MINUTE=30
