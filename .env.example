# Copy to .env and fill in values
ENVIRONMENT=development
REDIS_URL=redis://localhost:6379
AWS_REGION=ap-northeast-2
AWS_S3_BUCKET=fundamentals-pdf-temp
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_TIMEOUT=30
MAX_PDF_PAGES=50
MAX_PDF_SIZE_MB=20

# CORS — comma-separated list of allowed origins (JSON array format)
# Development: ["http://localhost:3000","http://localhost:8081"]
# Production:  ["https://yourapp.com"]
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:8081"]

# Gemini (무료 플랜) — 쉼표로 구분해서 여러 키 입력 가능
GEMINI_API_KEYS=your-gemini-key-1,your-gemini-key-2
GEMINI_MODEL=gemini-2.0-flash
GEMINI_TIMEOUT=60

# OpenAI (gpt plan) — user provides their own key at request time
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT=60

# TimelyGPT (timely plan) — https://timelygpt.co.kr — user provides their own key
# Supports 50+ models: gpt-4.1, gpt-4o, claude-sonnet-4-5, gemini-2.5-flash, etc.
TIMELY_MODEL=gpt-4.1
TIMELY_TIMEOUT=60

# Rate limiting — max requests per minute per IP
RATE_LIMIT_PER_MINUTE=30

# Redis TLS (set to true in production when Redis uses rediss:// URL)
REDIS_TLS_ENABLED=false
