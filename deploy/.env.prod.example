# Copy to .env.prod on the server. NEVER commit the real .env.prod.
# Path on server: /opt/study-helper-backend/deploy/.env.prod
#
# ── How values get filled ─────────────────────────────
# Bootstrap-only (set once during EC2 provisioning, kept on disk):
#   POSTGRES_USER, POSTGRES_DB, POSTGRES_PASSWORD, ALLOWED_ORIGINS, IMAGE
#
# Managed by GH Secrets → SSM Parameter Store → deploy.sh:
#   SUPABASE_URL, SUPABASE_SERVICE_ROLE_KEY, SUPABASE_JWT_SECRET,
#   SUPABASE_DB_URL, GEMINI_API_KEYS
# These are overwritten on every deploy by deploy.sh fetching from
# /study-helper/backend/* in SSM Parameter Store. Set the GH Secrets in
# the repo (Settings → Secrets and variables → Actions) — values below
# are only placeholders so the file parses cleanly before the first deploy.

# ── Image (CI overrides per deploy via deploy.sh) ──────
IMAGE=250847881242.dkr.ecr.ap-northeast-2.amazonaws.com/study-helper-backend:latest

# ── Postgres (bootstrap, auto-generate strong password) ──
POSTGRES_USER=study
POSTGRES_DB=studyhelper
POSTGRES_PASSWORD=

# ── Supabase (managed via Parameter Store) ─────────────
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=
SUPABASE_DB_URL=

# ── AI keys (managed via Parameter Store) ──────────────
GEMINI_API_KEYS=

# ── CORS — set to web origin (IP for now, swap for domain later) ──
ALLOWED_ORIGINS=["http://54.116.85.82"]
